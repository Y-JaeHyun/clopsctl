# clopsctl 환경 변수 — 실제 값은 .env 에 채워서 사용 (.env 는 git ignore)
#
# 사용 전 권한 강화:
#   cp .env.example .env && chmod 600 .env
#
# 절대 커밋·원격 저장소 업로드 금지

# LLM 백엔드 — 로컬 CLI 활용 (claude / gemini / codex 중 하나)
# 미지정 시 PATH 에서 자동 감지 (claude → gemini → codex 순)
# `clopsctl backend` 로 가용성 확인 가능
CLOPSCTL_LLM_BACKEND=claude

# 모델 라벨 (히스토리 기록용 메타데이터). 실제 모델 선택은 각 CLI 의 기본값/플래그를 따름.
CLOPSCTL_MODEL=claude-opus-4-7

# 인벤토리 파일 경로 (절대경로 권장)
CLOPSCTL_INVENTORY=./inventory/servers.toml

# 히스토리 SQLite 경로
CLOPSCTL_HISTORY_DB=./history/clopsctl.sqlite

# 위험 명령 confirm 게이트 (true/false)
CLOPSCTL_SAFETY_CONFIRM=true

# 권한 게이트 모드:
#   strict (기본, 안전 우선) — 대상 중 가장 엄격한 role 기준으로 전부 차단/통과
#   per_server               — 서버별 개별 검사, 통과한 서버에만 실행
# CLI 에서는 --per-server 플래그로 일시 override 가능
CLOPSCTL_PERMISSION_MODE=strict

# 웹 UI bind
CLOPSCTL_WEB_HOST=127.0.0.1
CLOPSCTL_WEB_PORT=8765
