# clopsctl 환경 변수 — 실제 값은 .env 에 채워서 사용 (.env 는 git ignore)
#
# 사용 전 권한 강화:
#   cp .env.example .env && chmod 600 .env
#
# 절대 커밋·원격 저장소 업로드 금지

# Anthropic API key — `clopsctl ask` (LLM 모드) 사용 시에만 필요
ANTHROPIC_API_KEY=

# 기본 Claude 모델
CLOPSCTL_MODEL=claude-opus-4-7

# 인벤토리 파일 경로 (절대경로 권장)
CLOPSCTL_INVENTORY=./inventory/servers.toml

# 히스토리 SQLite 경로
CLOPSCTL_HISTORY_DB=./history/clopsctl.sqlite

# 위험 명령 confirm 게이트 (true/false)
CLOPSCTL_SAFETY_CONFIRM=true

# 웹 UI bind
CLOPSCTL_WEB_HOST=127.0.0.1
CLOPSCTL_WEB_PORT=8765
